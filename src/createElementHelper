const createElement = function (tag, { classes = [], text = '', children = [] } = {}) {
    const element = document.createElement(tag);
    if (classes.length) element.classList.add(...classes);
    if (text) element.textContent = text;

    children.forEach(child => element.append(child));

    return element;
}

const createCard = function (cardClass = '', titleText = '', cardText = '') {
    return createElement('div', {
        classes: ['card', cardClass],
        children: [
            createElement('h3', { classes: ['card-title'], text: titleText }),
            createElement('p', { classes: ['card-text'], text: cardText })
        ]
    })
}

export { createElement, createCard };